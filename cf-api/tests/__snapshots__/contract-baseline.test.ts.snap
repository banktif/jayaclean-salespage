      "headers": {
        "cacheControl": "no-store",
        "contentType": "application/json; charset=utf-8",
        "cors": "*",
        "noSniff": "nosniff",
        "referrerPolicy": "no-referrer",
      },
      "status": 200,
    },
    "tasksUnauthorized": {
      "body": {
        "error": "Missing auth token",
      },
      "headers": {
        "cacheControl": "no-store",
        "contentType": "application/json; charset=utf-8",
        "cors": "*",
        "noSniff": "nosniff",
        "referrerPolicy": "no-referrer",
      },
      "status": 401,
    },
  },
}
`;
